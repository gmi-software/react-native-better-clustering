{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitromapcluster"
  ],
  "ios": {
    "iosModuleName": "NitroMapCluster"
  },
  "android": {
    "androidNamespace": [
      "nitromapcluster"
    ],
    "androidCxxLibName": "NitroMapCluster"
  },
  "autolinking": {
    "ClusterEngine": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridClusterEngine"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
